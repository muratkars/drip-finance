# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/drip_finance"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-change-in-production"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OCR Provider: "local" (Tesseract, free) or "claude" (Claude Vision API)
OCR_PROVIDER="local"
# Required only if OCR_PROVIDER=claude
ANTHROPIC_API_KEY=""
