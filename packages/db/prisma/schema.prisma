generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth Models (NextAuth) ─────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  accounts          Account[]
  sessions          Session[]
  transactions      Transaction[]
  assumptions       Assumption[]
  categories        Category[]
  goals             Goal[]
  financialAccounts FinancialAccount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Models ────────────────────────────────────────────

model Category {
  id       String          @id @default(cuid())
  name     String
  icon     String?
  color    String?
  type     TransactionType
  isSystem Boolean         @default(false)
  userId   String?

  user         User?              @relation(fields: [userId], references: [id])
  transactions Transaction[]
  items        TransactionItem[]
  assumptions  Assumption[]
  rules        CategoryRule[]

  @@unique([name, userId])
}

model CategoryRule {
  id         String    @id @default(cuid())
  categoryId String
  matchType  MatchType
  pattern    String
  priority   Int       @default(0)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
}

model FinancialAccount {
  id            String             @id @default(cuid())
  userId        String
  name          String
  type          FinancialAccountType
  balance       Decimal            @default(0) @db.Decimal(12, 2)
  institution   String?            // "Bank of America", "Chase", "Robinhood"
  lastFour      String?            // last 4 digits of account number
  color         String?
  isActive      Boolean            @default(true)

  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactionsFrom    Transaction[] @relation("TransactionFromAccount")
  transactionsTo      Transaction[] @relation("TransactionToAccount")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Transaction {
  id               String            @id @default(cuid())
  userId           String
  categoryId       String?
  accountId        String?           // primary account (where the money flows from/to)
  fromAccountId    String?           // for TRANSFER: source account
  toAccountId      String?           // for TRANSFER: destination account
  description      String
  cleanDescription String?
  amount           Decimal           @db.Decimal(12, 2)
  type             TransactionType
  date             DateTime
  spreadDays       Int               @default(1)
  dailyAmount      Decimal           @db.Decimal(12, 2)
  source           TransactionSource @default(MANUAL)
  rawCsvLine       String?
  isRecurring      Boolean           @default(false)
  recurringPeriod  RecurringPeriod?
  recurringType    RecurringType?
  uploadBatchId    String?
  dedupHash        String?
  receiptStatus    ReceiptStatus     @default(PENDING) // for receipt reminder system

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category?          @relation(fields: [categoryId], references: [id])
  fromAccount FinancialAccount?  @relation("TransactionFromAccount", fields: [fromAccountId], references: [id])
  toAccount   FinancialAccount?  @relation("TransactionToAccount", fields: [toAccountId], references: [id])
  items       TransactionItem[]
  receipts    Receipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([userId, categoryId])
  @@index([uploadBatchId])
  @@index([userId, dedupHash])
  @@index([fromAccountId])
  @@index([toAccountId])
}

model TransactionItem {
  id            String  @id @default(cuid())
  transactionId String
  name          String
  quantity      Int     @default(1)
  unitPrice     Decimal @db.Decimal(12, 2)
  totalPrice    Decimal @db.Decimal(12, 2)
  spreadDays    Int     @default(1)
  dailyAmount   Decimal @db.Decimal(12, 2)
  categoryId    String?

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  category    Category?   @relation(fields: [categoryId], references: [id])

  @@index([transactionId])
}

model Receipt {
  id            String  @id @default(cuid())
  transactionId String
  fileName      String
  fileType      String  // "image/jpeg", "image/png", "application/pdf"
  fileData      Bytes   // stored in DB for MVP, move to S3 later
  fileSize      Int

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([transactionId])
}

model Assumption {
  id         String         @id @default(cuid())
  userId     String
  categoryId String?
  name       String
  key        String
  value      Int
  unit       AssumptionUnit

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])

  @@unique([userId, key])
}

model Goal {
  id             String   @id @default(cuid())
  userId         String
  name           String
  type           GoalType
  targetAmount   Decimal  @db.Decimal(12, 2)
  currentAmount  Decimal  @default(0) @db.Decimal(12, 2)
  targetDate     DateTime?
  apr            Decimal? @db.Decimal(5, 2) // for PAY_DOWN goals
  monthlyPayment Decimal? @db.Decimal(12, 2) // planned monthly contribution/payment
  color          String?
  isCompleted    Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ─── Enums ──────────────────────────────────────────────────

enum GoalType {
  SAVE_UP
  PAY_DOWN
}

enum ReceiptStatus {
  PENDING     // no receipt, hasn't been prompted yet
  DISMISSED   // user said "not needed"
  MISSING     // user confirmed no receipt available
  UPLOADED    // receipt attached
}

enum FinancialAccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  INVESTMENT
  CASH
  LOAN
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionSource {
  MANUAL
  CSV_IMPORT
}

enum MatchType {
  CONTAINS
  STARTS_WITH
  REGEX
}

enum RecurringType {
  BILL          // essential, hard to cancel (mortgage, utilities, insurance)
  SUBSCRIPTION  // discretionary, can cancel (Netflix, gym, SaaS)
  INCOME        // recurring income (salary, freelance retainer)
}

enum RecurringPeriod {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum AssumptionUnit {
  DAYS
  WEEKS
  MONTHS
  YEARS
}
