generator client {
  provider      = "prisma-client-js"
  output        = "../generated/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth Models (NextAuth) ─────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  accounts     Account[]
  sessions     Session[]
  transactions Transaction[]
  assumptions  Assumption[]
  categories   Category[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Models ────────────────────────────────────────────

model Category {
  id       String          @id @default(cuid())
  name     String
  icon     String?
  color    String?
  type     TransactionType
  isSystem Boolean         @default(false)
  userId   String?

  user         User?              @relation(fields: [userId], references: [id])
  transactions Transaction[]
  items        TransactionItem[]
  assumptions  Assumption[]
  rules        CategoryRule[]

  @@unique([name, userId])
}

model CategoryRule {
  id         String    @id @default(cuid())
  categoryId String
  matchType  MatchType
  pattern    String
  priority   Int       @default(0)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
}

model Transaction {
  id               String            @id @default(cuid())
  userId           String
  categoryId       String?
  description      String
  cleanDescription String?
  amount           Decimal           @db.Decimal(12, 2)
  type             TransactionType
  date             DateTime
  spreadDays       Int               @default(1)
  dailyAmount      Decimal           @db.Decimal(12, 2)
  source           TransactionSource @default(MANUAL)
  rawCsvLine       String?
  isRecurring      Boolean           @default(false)
  recurringPeriod  RecurringPeriod?
  uploadBatchId    String?
  dedupHash        String?           // hash of date+description+amount for duplicate detection

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category?         @relation(fields: [categoryId], references: [id])
  items    TransactionItem[]
  receipts Receipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([userId, categoryId])
  @@index([uploadBatchId])
  @@index([userId, dedupHash])
}

model TransactionItem {
  id            String  @id @default(cuid())
  transactionId String
  name          String
  quantity      Int     @default(1)
  unitPrice     Decimal @db.Decimal(12, 2)
  totalPrice    Decimal @db.Decimal(12, 2)
  spreadDays    Int     @default(1)
  dailyAmount   Decimal @db.Decimal(12, 2)
  categoryId    String?

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  category    Category?   @relation(fields: [categoryId], references: [id])

  @@index([transactionId])
}

model Receipt {
  id            String  @id @default(cuid())
  transactionId String
  fileName      String
  fileType      String  // "image/jpeg", "image/png", "application/pdf"
  fileData      Bytes   // stored in DB for MVP, move to S3 later
  fileSize      Int

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([transactionId])
}

model Assumption {
  id         String         @id @default(cuid())
  userId     String
  categoryId String?
  name       String
  key        String
  value      Int
  unit       AssumptionUnit

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])

  @@unique([userId, key])
}

// ─── Enums ──────────────────────────────────────────────────

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionSource {
  MANUAL
  CSV_IMPORT
}

enum MatchType {
  CONTAINS
  STARTS_WITH
  REGEX
}

enum RecurringPeriod {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum AssumptionUnit {
  DAYS
  WEEKS
  MONTHS
  YEARS
}
